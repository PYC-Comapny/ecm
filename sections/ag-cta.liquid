<section class="ag-cta-section section-{{ section.id }}">
  <div class="ag-cta-container">
    <div class="ag-cta-content">
      {% if section.settings.heading != blank %}
        <h2 class="ag-cta-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="ag-cta-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      
      <div class="ag-cta-actions">
        <a href="{{ section.settings.button_link | default: '#checkout-section' }}" class="ag-cta-button button button--primary pulse-animation">
          {{ section.settings.button_label }}
        </a>
      </div>
      
      {% if section.settings.trust_text != blank %}
        <p class="ag-cta-trust">{{ section.settings.trust_text }}</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .ag-cta-section {
    padding: 60px 0;
    background-color: #ffffff;
    text-align: center;
    overflow: hidden;
  }

  .ag-cta-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ag-cta-heading {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: -0.03em;
    color: #1a1a1a;
    line-height: 1.1;
    margin-bottom: 15px;
  }

  .ag-cta-subheading {
    font-size: 18px;
    color: #4b5563;
    margin-bottom: 30px;
    line-height: 1.5;
  }

  .ag-cta-button {
    display: inline-block;
    background-color: #3cb371;
    color: #ffffff;
    padding: 20px 50px;
    border-radius: 50px;
    font-size: 20px;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 10px 30px rgba(60, 179, 113, 0.4);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .ag-cta-button:hover {
    background-color: #2e8b57;
    transform: scale(1.03);
  }

  .ag-cta-trust {
    margin-top: 20px;
    font-size: 14px;
    color: #9ca3af;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  @keyframes pulse-cta {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(60, 179, 113, 0.7); }
    70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(60, 179, 113, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(60, 179, 113, 0); }
  }

  .pulse-animation {
    animation: pulse-cta 2s infinite;
  }

  @media (max-width: 749px) {
    .ag-cta-section {
      padding: 40px 0;
    }
    .ag-cta-button {
      width: 100%;
      padding: 18px 20px;
      font-size: 18px;
    }
  }
</style>

{% schema %}
{
  "name": "AG Premium CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to Live Pain Free?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join 10,000+ happy customers who reclaimed their mobility today."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "YES! I WANT RELIEF NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/#checkout-section"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust Text",
      "default": "✓ 90-Day Money Back Guarantee"
    }
  ],
  "presets": [
    {
      "name": "AG Premium CTA"
    }
  ]
}
{% endschema %}
