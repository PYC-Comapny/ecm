<section class="ag-cta-section section-{{ section.id }} {% unless section.settings.ag_show_desktop %}hide-desktop{% endunless %} {% unless section.settings.ag_show_mobile %}hide-mobile{% endunless %}">
  <div class="ag-cta-container">
    <div class="ag-cta-content">
      {% if section.settings.ag_heading != blank %}
        <h2 class="ag-cta-heading">{{ section.settings.ag_heading }}</h2>
      {% endif %}
      {% if section.settings.ag_subheading != blank %}
        <p class="ag-cta-subheading">{{ section.settings.ag_subheading }}</p>
      {% endif %}
      
      <div class="ag-cta-actions">
        {%- liquid
          assign button_url = section.settings.ag_button_link
          if section.settings.ag_checkout_direct and button_url == blank
            assign button_url = '/checkout'
          elsif button_url == blank
            assign button_url = '#checkout-section'
          endif
        -%}
        <a href="{{ button_url }}" class="ag-cta-button button button--primary pulse-animation">
          {{ section.settings.ag_button_label }}
        </a>
      </div>
      
      {% if section.settings.ag_trust_text != blank %}
        <p class="ag-cta-trust">{{ section.settings.ag_trust_text }}</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --ag-heading-size: {{ section.settings.ag_font_h2 }}px;
    --ag-heading-size-mobile: {{ section.settings.ag_font_h2_mobile }}px;
  }

  .ag-cta-section {
    padding: 60px 0;
    background-color: #ffffff;
    text-align: center;
    overflow: hidden;
  }

  .ag-cta-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ag-cta-heading {
    font-size: var(--ag-heading-size);
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: -0.03em;
    color: #1a1a1a;
    line-height: 1.1;
    margin-bottom: 15px;
  }

  .ag-cta-subheading {
    font-size: 18px;
    color: #4b5563;
    margin-bottom: 30px;
    line-height: 1.5;
  }

  .ag-cta-button {
    display: inline-block;
    background-color: #3cb371;
    color: #ffffff;
    padding: 20px 50px;
    border-radius: 50px;
    font-size: 20px;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 10px 30px rgba(60, 179, 113, 0.4);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .ag-cta-button:hover {
    background-color: #2e8b57;
    transform: scale(1.03);
  }

  .ag-cta-trust {
    margin-top: 20px;
    font-size: 14px;
    color: #9ca3af;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  {% if section.settings.ag_show_desktop == false %}
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}.hide-desktop { display: none !important; }
    }
  {% endif %}

  {% if section.settings.ag_show_mobile == false %}
    @media screen and (max-width: 749px) {
      .section-{{ section.id }}.hide-mobile { display: none !important; }
    }
  {% endif %}

  @keyframes pulse-cta {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(60, 179, 113, 0.7); }
    70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(60, 179, 113, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(60, 179, 113, 0); }
  }

  .pulse-animation {
    animation: pulse-cta 2s infinite;
  }

  @media (max-width: 749px) {
    .ag-cta-section {
      padding: 40px 0;
    }
    .ag-cta-heading {
      font-size: var(--ag-heading-size-mobile);
    }
    .ag-cta-button {
      width: 100%;
      padding: 18px 20px;
      font-size: 18px;
    }
  }
</style>

{% schema %}
{
  "name": "AG Premium CTA",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "ag_heading",
      "label": "Heading",
      "default": "Ready to Live Pain Free?"
    },
    {
      "type": "textarea",
      "id": "ag_subheading",
      "label": "Subheading",
      "default": "Join 10,000+ happy customers who reclaimed their mobility today."
    },
    {
      "type": "text",
      "id": "ag_button_label",
      "label": "Button Label",
      "default": "YES! I WANT RELIEF NOW"
    },
    {
      "type": "url",
      "id": "ag_button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "ag_trust_text",
      "label": "Trust Text",
      "default": "✓ 90-Day Money Back Guarantee"
    },
    {
      "type": "header",
      "content": "Control Settings"
    },
    {
      "type": "checkbox",
      "id": "ag_show_desktop",
      "label": "Show on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "ag_show_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "ag_checkout_direct",
      "label": "Enable Direct Checkout",
      "default": false,
      "info": "When checked, and button link is empty, the button will go straight to /checkout"
    },
    {
      "type": "range",
      "id": "ag_font_h2",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 42
    },
    {
      "type": "range",
      "id": "ag_font_h2_mobile",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "AG Premium CTA"
    }
  ]
}
{% endschema %}
