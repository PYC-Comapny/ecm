<div class="anti-gravity-dashboard">
  <div class="diagnostic-panel vs-panel">
    
    <h2 class="vs-section-title">Why It Works & Why It's Better</h2>

    <!-- Comparison Table -->
    <div class="vs-table-container">
      
      <!-- Headers Row for Table -->
      <div class="vs-row header-row">
        <div class="vs-cell col-feature-head">FEATURES</div>
        <div class="vs-cell col-ours-head">ULTRA KNEE MASSAGER</div>
        <div class="vs-cell col-theirs-head">PILLS</div>
        <div class="vs-cell col-theirs-head">SURGERY</div>
      </div>

      <!-- Row: Side Effects -->
      <div class="vs-row text-based-row">
        <div class="vs-cell feature-name">SIDE EFFECTS</div>
        <div class="vs-cell col-ours">
          <span class="data-text text-green-color jump-in">None (Natural)</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="data-text text-red-color jump-in">Liver Damage / Brain Fog</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="data-text text-red-color jump-in">Infection / Long Recovery</span>
        </div>
      </div>

      <!-- Row: Cost -->
      <div class="vs-row text-based-row">
        <div class="vs-cell feature-name">COST</div>
        <div class="vs-cell col-ours">
          <span class="data-text text-green-color jump-in delay-1">One-time Payment</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="data-text text-red-color jump-in delay-1">Lifetime Monthly Cost</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="data-text text-red-color jump-in delay-1">$15,000+ (After Insurance)</span>
        </div>
      </div>

      <!-- Row: Result -->
      <div class="vs-row text-based-row">
        <div class="vs-cell feature-name">RESULT</div>
        <div class="vs-cell col-ours">
          <span class="data-text text-green-color font-bold jump-in delay-2">Immediate Relief</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="data-text text-red-color jump-in delay-2">Temporary Masking</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="data-text text-red-color jump-in delay-2">Permanent Alteration</span>
        </div>
      </div>

      <!-- Row 1 -->
      <div class="vs-row">
        <div class="vs-cell feature-name">RED LIGHT THERAPY</div>
        <div class="vs-cell col-ours">
          <span class="check-text jump-in delay-3">✔</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-3">✖</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-3">✖</span>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="vs-row">
        <div class="vs-cell feature-name">HANDS-FREE</div>
        <div class="vs-cell col-ours">
          <span class="check-text jump-in delay-4">✔</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-4">✖</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-4">✖</span>
        </div>
      </div>

      <!-- Row 3 -->
      <div class="vs-row">
        <div class="vs-cell feature-name">PORTABLE</div>
        <div class="vs-cell col-ours">
          <span class="check-text jump-in delay-4">✔</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-4">✖</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-4">✖</span>
        </div>
      </div>

      <!-- Row 4 -->
      <div class="vs-row">
        <div class="vs-cell feature-name">ADVANCED</div>
        <div class="vs-cell col-ours">
          <div class="simple-text jump-in delay-5">SIMPLE</div>
        </div>
        <div class="vs-cell col-theirs">
          <span class="check-text jump-in delay-5">✔</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="check-text jump-in delay-5">✔</span>
        </div>
      </div>

      <!-- Row 5 -->
      <div class="vs-row">
        <div class="vs-cell feature-name">AFFORDABLE</div>
        <div class="vs-cell col-ours">
          <span class="check-text jump-in delay-5">✔</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-5">✖</span>
        </div>
        <div class="vs-cell col-theirs">
          <span class="cross-text jump-in delay-5">✖</span>
        </div>
      </div>

    </div>

    <!-- Added Urgency & CTA -->
    <div class="vs-footer">
      <p class="vs-urgency">
        <strong>DON'T WAIT!</strong> Prevent serious injuries and surgeries before they begin.
      </p>
      <div class="vs-cta-wrapper">
        <a href="{{ section.settings.button_link | default: '#checkout-section' }}" class="vs-cta-button button button--primary cta-pulsing">
          {{ section.settings.button_label | default: 'YES! I WANT PAIN-FREE KNEES' }}
        </a>
      </div>
    </div>

  </div>
</div>

<style>
  /* Base Container Styles (inheriting aesthetic from Diagnostic Dashboard) */
  .anti-gravity-dashboard {
    padding: 40px 10px;
    background-color: transparent;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .diagnostic-panel.vs-panel {
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
    max-width: 900px;
    width: 100%;
    padding: 30px;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(229, 231, 235, 0.5);
  }

  .vs-footer {
    text-align: center;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px dashed #e5e7eb;
  }

  .vs-urgency {
    font-size: 16px;
    color: #cf3f5c;
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .vs-cta-button {
    background-color: #3cb371 !important;
    color: #ffffff !important;
    padding: 15px 45px !important;
    border-radius: 50px !important;
    font-size: 1.8rem !important;
    font-weight: 900 !important;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.2s ease, background-color 0.2s ease;
    box-shadow: 0 10px 25px rgba(60, 179, 113, 0.3);
    border: none;
    min-width: 300px;
    cursor: pointer;
    line-height: 1.2;
    display: inline-flex;
    justify-content: center;
    align-items: center;
  }

  .vs-cta-button:hover {
    background-color: #2e8b57;
    transform: scale(1.02);
    color: #ffffff !important;
  }

  .vs-cta-wrapper {
    display: flex;
    justify-content: center;
    padding-bottom: 10px;
  }

  @keyframes cta-pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(60, 179, 113, 0.6); }
    70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(60, 179, 113, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(60, 179, 113, 0); }
  }

  .cta-pulsing {
    animation: cta-pulse 2s infinite;
  }



  /* Table Section */
  .vs-section-title {
    font-size: 28px;
    font-weight: 900;
    text-align: center;
    color: #1F1F1F;
    margin-top: 0;
    margin-bottom: 25px;
    letter-spacing: -0.5px;
    text-transform: uppercase;
  }

  .vs-table-container {
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid #f3f4f6;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.03);
  }

  .header-row {
    background: #f9fafb;
    border-bottom: 2px solid #e5e7eb !important;
  }

  .col-feature-head, .col-ours-head, .col-theirs-head {
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    color: #6b7280;
    letter-spacing: 0.5px;
  }

  .col-ours-head {
    color: #10b981;
    white-space: nowrap;
  }

  .vs-row {
    display: grid;
    grid-template-columns: 2fr 1.25fr 1.25fr 1.25fr;
    border-bottom: 1px solid #f3f4f6;
    transition: background-color 0.2s ease;
  }

  .vs-row:last-child {
    border-bottom: none;
  }

  .vs-row:hover:not(.header-row) {
    background-color: #f9fafb;
  }

  .vs-cell {
    padding: 16px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .feature-name {
    justify-content: flex-start;
    text-align: left;
    font-size: 14px;
    font-weight: 800;
    color: #ffffff;
    background-color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .vs-row:nth-child(even) .feature-name {
    background-color: #475569;
  }

  .col-ours {
    border-left: 1px solid #f3f4f6;
    border-right: 1px solid #f3f4f6;
    background-color: rgba(16, 185, 129, 0.02);
  }

  .col-theirs {
    border-right: 1px solid #f3f4f6;
  }

  .col-theirs:last-child {
    border-right: none;
  }

  .check-text {
    font-size: 20px;
    font-weight: 900;
    color: #10b981;
  }
  
  .cross-text {
    font-size: 20px;
    font-weight: 900;
    color: #ef4444;
  }

  .simple-text {
    font-size: 14px;
    font-weight: 900;
    color: #ef4444;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .data-text {
    font-size: 11px;
    font-weight: 600;
    line-height: 1.4;
  }

  .text-green-color {
    color: #059669;
  }

  .text-red-color {
    color: #dc2626;
  }

  /* Animations for Icons */
  .jump-in {
    opacity: 0;
    animation: agJumpIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }
  .delay-3 { animation-delay: 0.6s; }
  .delay-4 { animation-delay: 0.8s; }

  @keyframes agJumpIn {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* Responsive Design */
  @media (max-width: 600px) {
    .vs-section-title {
      font-size: 22px;
      margin-bottom: 15px;
    }

    .feature-name {
      font-size: 12px;
      padding: 10px;
    }

    .check-text, .cross-text {
      font-size: 16px;
    }

    .simple-text {
      font-size: 12px;
    }
    
    .col-feature-head, .col-ours-head, .col-theirs-head {
      font-size: 11px;
      white-space: normal;
    }

    .vs-cta-button {
      width: 100%;
      min-width: unset;
      padding: 18px 20px;
      font-size: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Comparison VS Table",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "YES! I WANT PAIN-FREE KNEES"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/#checkout-section",
      "info": "Leave blank to scroll to checkout section"
    }
  ],
  "presets": [
    {
      "name": "Comparison VS Table",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
