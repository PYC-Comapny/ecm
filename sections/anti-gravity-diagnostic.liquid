<div class="anti-gravity-dashboard">
  <div class="diagnostic-panel">
    <!-- Header -->
    <div class="panel-header">
      <div class="header-left">
        <h2 class="panel-title">KNEE JOINT SCAN</h2>
        <span class="panel-subtitle">LIVE METRIC SCAN</span>
        <div class="window-controls">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
      </div>
      <div class="header-right">
        <div class="main-score">
          <div class="score-value">94.2%</div>
          <div class="score-indicator">
            <span class="up-arrow">↑</span>
            <span class="green-dot"></span>
            <span class="score-text">↑ 2.1% PREV_REP</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Graphic -->
    <div class="main-graphic-container">
      <img src="{{ 'knee-joint-anatomy.png' | asset_url }}" alt="Anatomical Knee Joint Scan" class="knee-joint-img">
      
      <!-- Crucial Overlay: Concentric Red Light Rings -->
      <div class="anti-grav-overlay">
        <div class="anti-grav-ring anti-grav-ring-1"></div>
        <div class="anti-grav-ring anti-grav-ring-2"></div>
        <div class="anti-grav-ring anti-grav-ring-3"></div>
        <div class="anti-grav-ring anti-grav-ring-4"></div>
        <div class="anti-grav-core"></div>
      </div>
    </div>

    <!-- Metric Boxes (Only 3 boxes now) -->
    <div class="metric-boxes">
      <div class="metric-box bg-red">
        <h3 class="box-header">CELLULAR REGENERATION</h3>
        <div class="box-score">200% Increase</div>
        <p class="box-text">Red Light Therapy Promotes Faster Recovery and Stronger Knees.</p>
        <div class="box-indicator green-dot"></div>
      </div>
      
      <div class="metric-box bg-green">
        <h3 class="box-header">DEEP TISSUE HEALING</h3>
        <div class="box-score">3-7 cm ↑ Penetration</div>
        <p class="box-text">Infrared Light Targets Deep-Seated Pain and Inflammation.</p>
      </div>

      <div class="metric-box bg-yellow">
        <h3 class="box-header">STIFFNESS REDUCTION</h3>
        <div class="box-score">30-50% Reduction</div>
        <p class="box-text">Heat Therapy Makes Movement Easier and Less Painful.</p>
      </div>
    </div>
  </div>
</div>

<style>
  .anti-gravity-dashboard {
    padding: 30px 10px;
    background-color: transparent; /* Changed from grey so it floats cleanly on the page */
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .diagnostic-panel {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.06), 0 3px 10px rgba(0,0,0,0.04);
    max-width: 650px; /* Made slightly wider to fit text properly */
    width: 100%;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }

  /* Header Styles */
  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .panel-title {
    font-size: 16px;
    font-weight: 800;
    color: #1F1F1F;
    margin: 0 0 2px 0;
    letter-spacing: -0.2px;
  }

  .panel-subtitle {
    font-size: 9px;
    color: #6b7280;
    font-weight: 600;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 8px;
  }

  .window-controls {
    display: flex;
    gap: 4px;
  }

  .window-controls .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #e5e7eb;
  }

  .main-score {
    text-align: right;
  }

  .score-value {
    font-size: 26px;
    font-weight: 800;
    color: #1F1F1F;
    line-height: 1;
    margin-bottom: 4px;
  }

  .score-indicator {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    color: #059669;
  }

  /* Universal Green Dot */
  .green-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #10b981;
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.5);
  }

  /* Graphic Container */
  .main-graphic-container {
    position: relative;
    width: 100%;
    height: 250px;
    margin-bottom: 25px;
  }

  .knee-joint-img {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 100%;
    width: auto;
    object-fit: contain;
    z-index: 1;
  }

  /* Red Light Overlay Animations */
  .anti-grav-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    height: 250px;
    z-index: 999999 !important;
    pointer-events: none;
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }

  .anti-grav-core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 14px !important;
    height: 14px !important;
    background-color: #ef4444 !important;
    border-radius: 50% !important;
    box-shadow: 0 0 15px 5px rgba(239, 68, 68, 1) !important;
    animation: agPulse 1.5s infinite ease-in-out !important;
    z-index: 999999 !important;
    display: block !important;
  }

  .anti-grav-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50% !important;
    border: 2px solid rgba(239, 68, 68, 0.8) !important;
    box-shadow: 0 0 8px rgba(239, 68, 68, 0.4) inset !important;
    opacity: 0;
    display: block !important;
  }

  .anti-grav-ring-1 { width: 25px; height: 25px; animation: agExpand 2s infinite 0s linear; }
  .anti-grav-ring-2 { width: 45px; height: 45px; animation: agExpand 2s infinite 0.5s linear; }
  .anti-grav-ring-3 { width: 65px; height: 65px; animation: agExpand 2s infinite 1.0s linear; }
  .anti-grav-ring-4 { width: 85px; height: 85px; animation: agExpand 2s infinite 1.5s linear; }

  @keyframes agPulse {
    0% { transform: translate(-50%, -50%) scale(0.85); box-shadow: 0 0 5px 2px rgba(239, 68, 68, 0.5) !important; }
    50% { transform: translate(-50%, -50%) scale(1.15); box-shadow: 0 0 15px 6px rgba(239, 68, 68, 0.85) !important; }
    100% { transform: translate(-50%, -50%) scale(0.85); box-shadow: 0 0 5px 2px rgba(239, 68, 68, 0.5) !important; }
  }

  @keyframes agExpand {
    0% { transform: translate(-50%, -50%) scale(0.4); opacity: 1; border-width: 2px; }
    100% { transform: translate(-50%, -50%) scale(1.4); opacity: 0; border-width: 1px; }
  }

  /* Metric Boxes */
  .metric-boxes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .metric-box {
    padding: 12px;
    border-radius: 10px;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .metric-box:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
  }

  .bg-green {
    background-color: rgba(60, 179, 113, 0.12); /* Enhanced Healing Green */
    border: 1px solid rgba(60, 179, 113, 0.3);
  }

  .bg-yellow {
    background-color: rgba(244, 208, 63, 0.18); /* Heat Therapy Yellow */
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .bg-red {
    background-color: rgba(239, 68, 68, 0.12); /* Redlight Therapy Red */
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .box-header {
    font-size: 9px;
    font-weight: 700;
    color: #4b5563;
    margin: 0 0 6px 0;
    letter-spacing: 0.3px;
  }

  .box-score {
    font-size: 15px;
    font-weight: 800;
    color: #1F1F1F;
    margin-bottom: 6px;
  }

  .box-text {
    font-size: 11px;
    color: #4b5563;
    line-height: 1.4;
    margin: 0;
  }

  .box-indicator {
    position: absolute;
    bottom: 10px;
    right: 10px;
  }

  .penetration-arrow {
    position: absolute;
    bottom: 8px;
    right: 10px;
    font-weight: bold;
    font-size: 14px;
    color: #b45309;
  }

  @media (max-width: 500px) {
    .metric-boxes {
      grid-template-columns: 1fr;
    }
    .panel-header {
      flex-direction: column;
      gap: 12px;
      align-items: center;
      text-align: center;
    }
    .main-score {
      text-align: center;
    }
    .score-indicator {
      justify-content: center;
    }
  }
</style>


