<style>
.premium-icon-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem; /* Clean spacing without breaking layout */
  padding: 2rem 1rem;
  margin: 0 auto;
  max-width: fit-content; /* Contains the width so it doesn't stretch and break desktop */
}
.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  text-align: center;
  /* Removed 'flex: 1' which was improperly stretching items on desktop */
}
.icon-circle {
  width: 75px;
  height: 75px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.icon-item:hover .icon-circle {
  transform: translateY(-5px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}
.icon-circle svg {
  z-index: 2;
  transition: transform 0.3s ease;
}
.icon-item:hover svg {
  transform: scale(1.1);
}

/* Delicate monochromatic tinted backgrounds */
.circle-green { background: rgba(60, 179, 113, 0.12); }
.circle-yellow { background: rgba(244, 208, 63, 0.18); }
.circle-red { background: rgba(239, 68, 68, 0.12); }

.icon-label {
  font-family: var(--font-heading-family), sans-serif;
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.95rem;
  letter-spacing: 0.05em;
  color: var(--color-foreground, #1F1F1F); 
    line-height: 1.3;
}
.icon-separator {
  font-size: 2.5rem;
  font-weight: 300;
  color: rgba(var(--color-foreground, 31, 31, 31), 0.2); 
  margin-bottom: 2.5rem; /* Aligns mathematically with the circles */
  line-height: 1;
}

@media (max-width: 600px) {
  .premium-icon-bar {
    gap: 0.75rem;
    padding: 1.5rem 0.5rem;
  }
  .icon-circle {
    width: 60px;
    height: 60px;
  }
  .icon-circle svg {
    width: 26px;
    height: 26px;
  }
  .icon-label {
    font-size: 0.75rem;
    letter-spacing: 0;
  }
  .icon-separator {
    font-size: 2rem;
    margin-bottom: 2rem;
  }
}
</style>

<div class="premium-icon-bar animate-on-scroll stagger-1">
  
  <!-- Enhanced Healing (Green Focus) -->
  <div class="icon-item">
    <div class="icon-circle circle-green">
      <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#3CB371" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
      </svg>
    </div>
    <span class="icon-label">Enhanced<br>Healing</span>
  </div>

  <span class="icon-separator">+</span>

  <!-- Heat Therapy (Yellow Focus) -->
  <div class="icon-item">
    <div class="icon-circle circle-yellow">
      <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
      </svg>
    </div>
    <span class="icon-label">Heat<br>Therapy</span>
  </div>

  <span class="icon-separator">+</span>

  <!-- Redlight Therapy (Red Focus) -->
  <div class="icon-item">
    <div class="icon-circle circle-red">
      <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2"/><path d="M12 20v2"/>
        <path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/>
        <path d="M2 12h2"/><path d="M20 12h2"/>
        <path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
      </svg>
    </div>
    <span class="icon-label">Redlight<br>Therapy</span>
  </div>

</div>

