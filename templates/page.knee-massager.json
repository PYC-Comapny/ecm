o move freely and see life for what it is ~ Premium Heals<\/strong><\/p>","text_style":"body"}},"button_H3QMgJ":{"type":"button","settings":{"button_label":"GET IT","button_link":"#checkout-section","button_style_secondary":false}}},"block_order":["heading_rRwbtr","text_CWxjky","button_H3QMgJ"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/zzzz_snoring_zzzz.jpg","height":"adapt","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"scheme-156b13b9-b85d-4aea-b2d5-bc69b8208eff","color_scheme":"scheme-156b13b9-b85d-4aea-b2d5-bc69b8208eff","padding_top":36,"padding_bottom":36}},"rich_text_ghawPy":{"type":"rich-text","blocks":{"heading_TfMcFT":{"type":"heading","settings":{"heading":"How To Use","heading_size":"h1"}},"text_XyMbGC":{"type":"text","settings":{"text":"<p><strong>1. Put it on your knee<\/strong> and wrap the strap snug (not too tight).<br\/><strong>2. Press the power button<\/strong> to turn it on.<br\/><strong>3. Choose what your levels of heat, massager(vibrations), and red light. <\/strong>(You can start at 1 if you are just beginning.)<\/p><p><strong>4. Relax for 10 minutes<\/strong> while it works. (you can choose to do it longer if you want.)<br\/><strong>5. Turn it off and remove<\/strong> when finished.<br\/><\/p><p><strong>That’s it. Simplicity is the Key.<\/strong><\/p>"}}},"block_order":["heading_TfMcFT","text_XyMbGC"],"disabled":true,"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"scheme-156b13b9-b85d-4aea-b2d5-bc69b8208eff","full_width":true,"padding_top":0,"padding_bottom":0}},"image_with_text_mYERqV":{"type":"image-with-text","blocks":{"heading_8TmHKA":{"type":"heading","settings":{"heading":"Why You'll Love  IT!","h