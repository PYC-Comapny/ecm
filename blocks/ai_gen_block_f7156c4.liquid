{% doc %}
  @prompt
    Create a newsletter email signup form that displays a custom success message "Use code HEALME20" only after the form is successfully submitted. The success message should replace or appear after the form submission, making it clear to customers they can use this discount code. The form should include an email input field and a submit button with appropriate styling., says there is a liquid error, okay this is good change the chema colors to Schema 6, make the email box also match the schema
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-signup-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-newsletter-signup__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-newsletter-signup__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-newsletter-signup__subtext-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subtext_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtext_size }}px;
    text-align: {{ block.settings.text_alignment }};
    opacity: 0.9;
  }

  .ai-newsletter-signup__form-wrapper-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-newsletter-signup__field-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.field_gap }}px;
    margin-bottom: 12px;
  }

  .ai-newsletter-signup__input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_thickness }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
  }

  .ai-newsletter-signup__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_text_color }};
    opacity: 0.6;
  }

  .ai-newsletter-signup__input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-newsletter-signup__button-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .ai-newsletter-signup__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-newsletter-signup__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: 8px;
  }

  .ai-newsletter-signup__success-{{ ai_gen_id }} {
    padding: {{ block.settings.success_padding }}px;
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-newsletter-signup__success-title-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.success_title_size }}px;
    font-weight: 700;
  }

  .ai-newsletter-signup__success-message-{{ ai_gen_id }} {
    margin: 0 0 16px;
    font-size: {{ block.settings.success_message_size }}px;
  }

  .ai-newsletter-signup__success-code-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.code_background_color }};
    color: {{ block.settings.code_text_color }};
    border-radius: {{ block.settings.code_border_radius }}px;
    font-size: {{ block.settings.code_font_size }}px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-signup__field-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-newsletter-signup__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<newsletter-signup-{{ ai_gen_id }}
  class="ai-newsletter-signup-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-newsletter-signup__container-{{ ai_gen_id }}">
    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div class="ai-newsletter-signup__success-{{ ai_gen_id }}">
          {%- if block.settings.success_title != blank -%}
            <h3 class="ai-newsletter-signup__success-title-{{ ai_gen_id }}">
              {{ block.settings.success_title }}
            </h3>
          {%- endif -%}
          {%- if block.settings.success_message != blank -%}
            <div class="ai-newsletter-signup__success-message-{{ ai_gen_id }}">
              {{ block.settings.success_message }}
            </div>
          {%- endif -%}
          <div class="ai-newsletter-signup__success-code-{{ ai_gen_id }}">
            {{ block.settings.discount_code }}
          </div>
        </div>
      {%- else -%}
        {%- if block.settings.heading != blank -%}
          <h2 class="ai-newsletter-signup__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if block.settings.subtext != blank -%}
          <div class="ai-newsletter-signup__subtext-{{ ai_gen_id }}">
            {{ block.settings.subtext }}
          </div>
        {%- endif -%}

        <div class="ai-newsletter-signup__form-wrapper-{{ ai_gen_id }}">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="ai-newsletter-signup__field-{{ ai_gen_id }}">
            <input
              type="email"
              name="contact[email]"
              class="ai-newsletter-signup__input-{{ ai_gen_id }}"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-newsletter-signup-error-{{ ai_gen_id }}"
              {% endif %}
              placeholder="{{ block.settings.email_placeholder }}"
              required
            >
            <button
              type="submit"
              class="ai-newsletter-signup__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </button>
          </div>
          {%- if form.errors -%}
            <div
              id="ai-newsletter-signup-error-{{ ai_gen_id }}"
              class="ai-newsletter-signup__error-{{ ai_gen_id }}"
            >
              {{ form.errors.messages.email }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</newsletter-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('newsletter-signup-{{ ai_gen_id }}', NewsletterSignup{{ ai_gen_id }});
  })();
</script>

