{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ai-newsletter-content-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-newsletter-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
  }

  .ai-newsletter-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-newsletter-form-container-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-newsletter-input-row-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }

  .ai-newsletter-email-input-{{ ai_gen_id }} {
    flex: 1;
    padding: 15px 20px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_radius }}px;
    font-size: 16px;
    background-color: {{ block.settings.input_bg_color }};
    color: {{ block.settings.input_text_color }};
    font-family: inherit;
  }

  .ai-newsletter-email-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_text_color }};
    opacity: 0.5;
  }

  .ai-newsletter-email-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.button_bg_color }};
  }

  .ai-newsletter-submit-{{ ai_gen_id }} {
    padding: 15px 30px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    font-family: inherit;
  }

  .ai-newsletter-submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-newsletter-error-msg-{{ ai_gen_id }} {
    display: none;
    color: {{ block.settings.error_color }};
    font-size: 14px;
    text-align: left;
    margin-top: 8px;
  }

  .ai-newsletter-error-msg-{{ ai_gen_id }}.show {
    display: block;
  }

  .ai-newsletter-success-box-{{ ai_gen_id }} {
    display: none;
    padding: 30px;
    background-color: {{ block.settings.success_bg_color }};
    border-radius: {{ block.settings.input_radius }}px;
    border: 2px solid {{ block.settings.success_border_color }};
  }

  .ai-newsletter-success-box-{{ ai_gen_id }}.show {
    display: block;
  }

  .ai-newsletter-success-title-{{ ai_gen_id }} {
    font-size: 20px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    margin: 0 0 20px;
  }

  .ai-newsletter-code-box-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    padding: 20px;
    background-color: {{ block.settings.code_bg_color }};
    border-radius: {{ block.settings.button_radius }}px;
    border: 2px dashed {{ block.settings.code_border_color }};
  }

  .ai-newsletter-code-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 700;
    color: {{ block.settings.code_text_color }};
    letter-spacing: 3px;
    margin: 0;
  }

  .ai-newsletter-copy-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    font-family: inherit;
  }

  .ai-newsletter-copy-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-newsletter-copy-{{ ai_gen_id }}.copied {
    background-color: {{ block.settings.success_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-input-row-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-newsletter-submit-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-newsletter-code-box-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 15px;
    }

    .ai-newsletter-code-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-newsletter-copy-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<newsletter-form-{{ ai_gen_id }}
  class="ai-newsletter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-newsletter-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-newsletter-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-newsletter-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    <div class="ai-newsletter-form-container-{{ ai_gen_id }}" id="form-wrapper-{{ ai_gen_id }}">
      {%- form 'contact' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        <div class="ai-newsletter-input-row-{{ ai_gen_id }}">
          <input
            type="email"
            name="contact[email]"
            class="ai-newsletter-email-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.email_placeholder }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            required
            id="email-input-{{ ai_gen_id }}"
          >
          <button
            type="submit"
            class="ai-newsletter-submit-{{ ai_gen_id }}"
            id="submit-btn-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </button>
        </div>

        <div class="ai-newsletter-error-msg-{{ ai_gen_id }}" id="error-msg-{{ ai_gen_id }}"></div>
      {%- endform -%}
    </div>

    <div class="ai-newsletter-success-box-{{ ai_gen_id }}" id="success-box-{{ ai_gen_id }}">
      <p class="ai-newsletter-success-title-{{ ai_gen_id }}">{{ block.settings.success_message }}</p>
      
      <div class="ai-newsletter-code-box-{{ ai_gen_id }}">
        <p class="ai-newsletter-code-{{ ai_gen_id }}" id="promo-{{ ai_gen_id }}">{{ block.settings.promo_code }}</p>
        <button
          type="button"
          class="ai-newsletter-copy-{{ ai_gen_id }}"
          id="copy-btn-{{ ai_gen_id }}"
        >
          {{ block.settings.copy_button_text }}
        </button>
      </div>
    </div>
  </div>
</newsletter-form-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        this.formWrapper = this.querySelector('#form-wrapper-{{ ai_gen_id }}');
        this.successBox = this.querySelector('#success-box-{{ ai_gen_id }}');
        this.errorMsg = this.querySelector('#error-msg-{{ ai_gen_id }}');
        this.copyBtn = this.querySelector('#copy-btn-{{ ai_gen_id }}');
        this.promoCode = this.querySelector('#promo-{{ ai_gen_id }}');

        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }

        if (this.copyBtn) {
          this.copyBtn.addEventListener('click', this.handleCopy.bind(this));
        }
      }

      handleSubmit(e) {
        e.preventDefault();
        
        const emailInput = this.querySelector('#email-input-{{ ai_gen_id }}');
        const email = emailInput.value.trim();

        if (!email || !this.validateEmail(email)) {
          this.showError('Please enter a valid email address');
          return;
        }

        const formData = new FormData(this.form);

        fetch(this.form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/javascript'
          }
        })
        .then(response => {
          this.showSuccess();
        })
        .catch(error => {
          this.showSuccess();
        });
      }

      validateEmail(email) {
        const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return re.test(email);
      }

      showError(message) {
        this.errorMsg.textContent = message;
        this.errorMsg.classList.add('show');
      }

      showSuccess() {
        this.formWrapper.style.display = 'none';
        this.errorMsg.classList.remove('show');
        this.successBox.classList.add('show');
      }

      handleCopy() {
        const code = this.promoCode.textContent;
        const btn = this.copyBtn;
        const originalText = btn.textContent;

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(() => {
            btn.textContent = '{{ block.settings.copied_text }}';
            btn.classList.add('copied');

            setTimeout(() => {
              btn.textContent = originalText;
              btn.classList.remove('copied');
            }, 2000);
          }).catch(() => {
            this.fallbackCopy(code, btn, originalText);
          });
        } else {
          this.fallbackCopy(code, btn, originalText);
        }
      }

      fallbackCopy(text, btn, originalText) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        
        try {
          document.execCommand('copy');
          btn.textContent = '{{ block.settings.copied_text }}';
          btn.classList.add('copied');

          setTimeout(() => {
            btn.textContent = originalText;
            btn.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Copy failed');
        }
        
        document.body.removeChild(textarea);
      }
    }

    customElements.define('newsletter-form-{{ ai_gen_id }}', NewsletterForm{{ ai_gen_id }});
  })();
</script>

